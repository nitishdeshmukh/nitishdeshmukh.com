# ==========================================
# Frontend (apps/web) 
# -> Copy to apps/web/.env.local
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ==========================================
# Admin (apps/admin)
# -> Copy to apps/admin/.env.local
# ==========================================
API_URL=http://localhost:8787
API_SECRET=super-secret-local-key

# ==========================================
# Backend API (apps/api)
# -> Copy to apps/api/.dev.vars
# ==========================================
API_SECRET=super-secret-local-key
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
